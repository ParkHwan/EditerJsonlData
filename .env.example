# ── EditerJsonlData 환경 변수 템플릿 ──
# 이 파일을 복사하여 환경별 설정 파일로 사용:
#   .env.local       → 로컬 개발 환경
#   .env.production  → GCP Compute Engine 운영 환경
#   .env             → 기본값 (비-Docker 로컬 개발)

# Environment: "local" | "production"
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=DEBUG
WORKERS=1
ALLOWED_HOSTS=*
GUNICORN_TIMEOUT=120

# Security
SECRET_KEY=changethis-in-production-secret-key-12345

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_SERVICE_NAME=mymaster

# Session
SESSION_TTL_HOURS=48
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Filesystem
DATA_DIR=data
BACKUP_DIR=data/backups

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_WRITE=30/minute

# Audit
AUDIT_DIR=data/audit
AUDIT_RETENTION_DAYS=90

# Draft
DRAFT_TTL_SECONDS=1800
DRAFT_AUTO_SAVE_INTERVAL=30

# Health Check
DISK_USAGE_WARNING_PCT=90.0

# 이메일 도메인 제한
ALLOWED_EMAIL_DOMAIN=crowdworks.kr

# GCS (Phase 6)
GCS_PROJECT_ID=crowdworks-platform
GCS_BUCKET_NAME=de-download-service-storage
GCS_PREFIX=manual
GCS_LOCATION=asia-northeast1
GCS_CREDENTIALS_PATH=
